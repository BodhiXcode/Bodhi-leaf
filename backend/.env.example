# AWS credentials -- generate from IAM console for your personal account
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS region (us-east-1 has full support for Bedrock Nova + Polly generative)
AWS_REGION=us-east-1

# Bedrock model ID (Nova Micro: $0.035/1M input, $0.14/1M output)
BEDROCK_MODEL_ID=us.amazon.nova-micro-v1:0
